# Anthropic — powers triage + brief. console.anthropic.com
ANTHROPIC_API_KEY=
# Model names live here so they can be upgraded without code changes.
# BRIEF_MODEL is the base for the daily brief, weekly/monthly/farmer/education
# memos, Market Pulse, market cards, and the Ask box.
TRIAGE_MODEL=claude-haiku-4-5
BRIEF_MODEL=claude-sonnet-5
# Optional — overrides just the Analyst Note (deep report), which runs on Opus 4.8
# with adaptive thinking. Clear to fall back to BRIEF_MODEL.
ANALYST_MODEL=claude-opus-4-8
# Optional — model for the per-item "AI summary" button. Defaults to BRIEF_MODEL.
SUMMARY_MODEL=

# Congress.gov — free key: https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=

# LegiScan — free key: https://legiscan.com/legiscan
LEGISCAN_API_KEY=

# Federal Register — no key needed. EUR-Lex OJ RSS — no key needed.

# Teams incoming webhook URL (optional)
TEAMS_WEBHOOK_URL=

# Optional SMTP for email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
BRIEF_EMAIL_TO=

# ============================================================
# v2 (Bean Brief v2) — see docs/V2.md
# ============================================================

# OpenStates (state legislators registry). Free: https://open.pluralpolicy.com
OPENSTATES_API_KEY=
# FEC (federal candidates registry). Free: https://api.data.gov/signup/
FEC_API_KEY=

# Collector Gmail for email-intake (see docs/collector-gmail.md).
# IMAP needs a Google APP PASSWORD (2FA on), NOT the account password.
EMAIL_INTAKE_HOST=imap.gmail.com
EMAIL_INTAKE_PORT=993
EMAIL_INTAKE_USER=
EMAIL_INTAKE_PASS=

# Farmer-facing brief (second render). Comma-separated recipients; blank = save/web only.
FARMER_BRIEF_TO=

# IECDB / data.iowa.gov (IA candidates & committees) — COMPLIANCE-GATED under Iowa
# Code § 68B.32A(7) (no commercial use / solicitation). Only set these after counsel
# confirms informational-only use. See docs/V2.md and §10 of the v2 plan.
IECDB_INFORMATIONAL_USE=
IECDB_DATASET_ID=
SOCRATA_APP_TOKEN=

# ============================================================
# Markets (demand-side data → Markets tab). All free keys.
# ============================================================
# USDA NASS Quick Stats (soybean price/production/stocks) — https://quickstats.nass.usda.gov/api
NASS_API_KEY=
# EIA (biofuel feedstock: soy oil → biodiesel/renewable diesel; + diesel) — https://www.eia.gov/opendata/register.php
EIA_API_KEY=
# USDA AMS My Market News (regional cash grain / basis) — https://mymarketnews.ams.usda.gov
USDA_AMS_API_KEY=
# USDA FAS Export Sales (ESR) — https://apps.fas.usda.gov/opendatawebv2 (sent as an API_KEY header)
FAS_API_KEY=
# USDA Ag Transport (agtransport.usda.gov, Socrata): export inspections + net export sales
# (FAS stand-in) + barge freight. Works with NO key; an optional free app token lifts the
# rate limit — https://agtransport.usda.gov/profile/edit/developer_settings
AGTRANSPORT_APP_TOKEN=
# Barchart OnDemand (CBOT futures + forward curve + local elevator basis) — PAID (free eval tier).
# Scaffold ships disabled; set this + enable `barchart` in watchlist.json once access lands.
BARCHART_API_KEY=
# FRED / St. Louis Fed (macro overlay: broad dollar index, 10-year yield) — free key:
# https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
# CFTC fund positioning + Open-Meteo weather + Drought Monitor + IBGE Brazil need NO key.

# Optional: email the "what changed" alert digest. Set watchlist output.alertEmail=true to enable;
# sends to ALERT_EMAIL_TO (falls back to BRIEF_EMAIL_TO) using the SMTP settings above.
ALERT_EMAIL_TO=
